<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{partyName}} — 채팅방</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">

    <!-- 채팅 스타일 -->
    <link rel="stylesheet" href="/css/chat.css">
</head>
<body>

<div class="chat-card">

    <!-- 헤더 -->
    <div class="chat-header">
        <div class="chat-header-icon">💬</div>
        <div>
            <h1>{{partyName}}의 채팅방</h1>
            <div class="chat-header-meta">파티 ID: {{partyId}} &nbsp;|&nbsp; 채팅방 ID: {{roomId}}</div>
        </div>
    </div>

    <!-- 사용자 표시 바 -->
    <div class="user-bar">
        <span class="user-bar-label">참여 중:</span>
        <span class="user-bar-name">{{userName}}</span>
        <button id="disconnectButton" onclick="disconnect()" style="display:none;">나가기</button>
    </div>

    <!-- 채팅 창 -->
    <div id="chat-window"></div>

    <!-- 메시지 입력 -->
    <div class="input-area">
        <input
                type="text"
                id="message-input"
                placeholder="메시지를 입력하세요..."
                autocomplete="off"
        >
        <button id="sendMessageButton" onclick="sendMessage()" title="보내기">
            ➤
        </button>
    </div>

</div>

<!-- STOMP / SockJS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/sockjs-client/1.5.1/sockjs.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/stomp.js/2.3.3/stomp.min.js"></script>

<!-- Mustache 서버 데이터 → JS 전달 -->
<script>
    window.CHAT_CONFIG = {
        partyId:  {{partyId}},
        roomId:   {{roomId}},
        userName: '{{userName}}'
    };
</script>

<!-- 채팅 로직 -->
<script src="/js/chat.js"></script>

{{>layout/footer}}
