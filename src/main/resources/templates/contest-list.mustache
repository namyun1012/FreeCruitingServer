<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Contest - FreeCruiting</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/contest.css">
</head>
<body>

<h1>FreeCruiting</h1>
<div class="col-md-12">
    {{>layout/userinfo}}
    <br>
    {{>layout/navigate}}

    <div class="mt-3">
        <!-- 검색 바 -->
        <form action="/contest" method="get" class="mb-3">
            {{#currentCategory}}
            <input type="hidden" name="category" value="{{currentCategory}}">
            {{/currentCategory}}
            <div class="input-group">
                <input type="text" name="keyword" class="form-control"
                       placeholder="공모전 제목, 주최기관 검색..."
                       value="{{currentKeyword}}">
                <div class="input-group-append">
                    <button class="btn btn-outline-secondary" type="submit">검색</button>
                </div>
            </div>
        </form>

        <!-- 카테고리 필터 -->
        <div class="category-filter">
            <a href="/contest" class="btn btn-outline-secondary category-filter-btn" data-category="">전체</a>
            <a href="/contest?category=PROGRAMMING" class="btn btn-outline-secondary category-filter-btn" data-category="PROGRAMMING">개발·IT</a>
            <a href="/contest?category=DESIGN" class="btn btn-outline-secondary category-filter-btn" data-category="DESIGN">디자인</a>
            <a href="/contest?category=STARTUP" class="btn btn-outline-secondary category-filter-btn" data-category="STARTUP">창업</a>
            <a href="/contest?category=ART" class="btn btn-outline-secondary category-filter-btn" data-category="ART">예술</a>
            <a href="/contest?category=SOCIAL" class="btn btn-outline-secondary category-filter-btn" data-category="SOCIAL">사회</a>
            <a href="/contest?category=ESSAY" class="btn btn-outline-secondary category-filter-btn" data-category="ESSAY">글·에세이</a>
            <a href="/contest?category=VIDEO" class="btn btn-outline-secondary category-filter-btn" data-category="VIDEO">영상</a>
            <a href="/contest?category=MARKETING" class="btn btn-outline-secondary category-filter-btn" data-category="MARKETING">마케팅</a>
            <a href="/contest?category=OTHER" class="btn btn-outline-secondary category-filter-btn" data-category="OTHER">기타</a>
        </div>

        <!-- 공모전 카드 목록 -->
        <div class="row">
            {{#contests}}
            <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <a href="/contest/read/{{id}}" style="text-decoration:none;color:inherit;">
                    <div class="contest-card">
                        {{#imageUrl}}
                        <img src="{{imageUrl}}" class="contest-card-img" alt="">
                        {{/imageUrl}}
                        {{^imageUrl}}
                        <div class="contest-card-img-placeholder">🏆</div>
                        {{/imageUrl}}
                        <div class="contest-card-body">
                            <div class="mb-1">
                                <span class="badge badge-secondary mr-1">{{category}}</span>
                                <span class="badge badge-{{status}}">{{status}}</span>
                            </div>
                            <p class="contest-card-title">{{title}}</p>
                            <p class="contest-card-organizer">{{organizer}}</p>
                        </div>
                        <div class="contest-card-footer d-flex justify-content-between">
                            <span>마감 {{applicationDeadline}}</span>
                            <span>조회 {{views}}</span>
                        </div>
                    </div>
                </a>
            </div>
            {{/contests}}
            {{^contests}}
            <div class="col-12">
                <p class="text-muted text-center py-5">공모전이 없습니다.</p>
            </div>
            {{/contests}}
        </div>

        <!-- 페이지네이션 -->
        <div class="d-flex justify-content-center">
            {{>layout/pages}}
        </div>
    </div>
</div>

{{>layout/footer}}
<script src="/js/contest.js"></script>
